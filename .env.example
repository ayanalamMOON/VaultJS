PORT=3001
GATEWAY_PORT=4000
DEMO_PORT=4100

# Set to false to run SQLite-only / in-memory mode (no Redis)
REDIS_ENABLED=false

# Option A (recommended): full Redis URL
REDIS_URL=redis://localhost:6379

# Option B: discrete Redis settings (useful for Redis Cloud, when REDIS_ENABLED=true)
# REDIS_HOST=redis-xxxx.c9.us-east-1-2.ec2.cloud.redislabs.com
# REDIS_PORT=19744
# REDIS_USERNAME=default
# REDIS_PASSWORD=replace_with_redis_password
# REDIS_TLS=true
MASTER_SECRET=replace_me
HMAC_KEY=replace_me

# Admin API token for /admin/* endpoints (required to enable admin controls)
ADMIN_API_TOKEN=replace_with_strong_admin_token

# Validation policy profile: strict | balanced | compat
VAULT_POLICY_PROFILE=balanced

# Optional HMAC key to sign SIEM export payloads (x-vault-export-signature)
SIEM_EXPORT_SIGNING_KEY=replace_with_random_signing_key

# Optional dedicated key for signed manifest files (falls back to SIEM_EXPORT_SIGNING_KEY)
SIEM_MANIFEST_SIGNING_KEY=replace_with_random_manifest_signing_key

# Optional directory for immutable manifest files
SIEM_MANIFEST_DIR=infra/db/export-manifests
